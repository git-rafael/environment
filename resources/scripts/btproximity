#!/usr/bin/env bash
set -euo pipefail;

# Bluetooth Proximity Screen Lock
# Locks the session when ALL paired devices move out of range.
# Configuration via environment variables (set by systemd service):
#   BT_DEVICE_MACS   - Space-separated list of Bluetooth MAC addresses
#   BT_LOCK_THRESHOLD   - RSSI threshold for locking (default: -20 dBm)
#   BT_UNLOCK_THRESHOLD - RSSI threshold for unlocking (default: -10 dBm)
#   BT_POLL_INTERVAL    - Seconds between readings
#   BT_LOCK_AFTER       - Consecutive readings with all devices out of range before locking (default: 3)

readonly LOCK_THRESHOLD="${BT_LOCK_THRESHOLD:--20}";
readonly UNLOCK_THRESHOLD="${BT_UNLOCK_THRESHOLD:--10}";
readonly LOCK_AFTER="${BT_LOCK_AFTER:-3}";
readonly POLL_INTERVAL="${BT_POLL_INTERVAL:-5}";
readonly CONNECT_RETRY_SECS="${BT_CONNECT_RETRY_SECS:-30}";

consecutive=0;
declare -A last_connect_attempt=();

if [[ -z "$BT_DEVICE_MACS" ]]; then
  echo "BT_DEVICE_MACS is not set" >&2;
  exit 1;
fi

log() { echo "[$(date '+%H:%M:%S')] $*"; }

is_connected() {
  bluetoothctl info "$1" 2>/dev/null | grep -q "Connected: yes";
}

maybe_connect() {
  local mac="$1";
  local now last;

  now=$(date +%s);
  last="${last_connect_attempt[$mac]:-0}";

  if (( now - last < CONNECT_RETRY_SECS )); then
    return 1;
  fi

  last_connect_attempt["$mac"]="$now";
  log "Requesting Bluetooth connection to $mac";
  bluetoothctl connect "$mac" >/dev/null 2>&1 || true;
}

any_in_range() {
  local threshold="${1:-$LOCK_THRESHOLD}";
  # word splitting intentional: iterates space-separated MACs
  for mac in $BT_DEVICE_MACS; do
    local rssi;
    if ! is_connected "$mac"; then
      maybe_connect "$mac";
      continue;
    fi

    rssi=$(hcitool rssi "$mac" 2>/dev/null | grep -oP '[-]?\d+');
    [[ -n "$rssi" ]] && [[ "$rssi" -ge "$threshold" ]] && return 0;
  done
  return 1;
}

wait_for_device() {
  until any_in_range "$UNLOCK_THRESHOLD"; do
    sleep "$POLL_INTERVAL";
  done
}

monitor() {
  local consecutive=0;
  while true; do
    if any_in_range "$LOCK_THRESHOLD"; then
      consecutive=0;
    else
      consecutive=$((consecutive + 1));
      log "All devices out of range ($consecutive/$LOCK_AFTER)";
      if [[ "$consecutive" -ge "$LOCK_AFTER" ]]; then
        log "Locking session";
        loginctl lock-session;
        consecutive=0;
        log "Waiting for a device to come back...";
        wait_for_device;
        log "Device back in range, unlocking session";
        loginctl unlock-session;
        dbus-send --session --dest=org.freedesktop.ScreenSaver /org/freedesktop/ScreenSaver org.freedesktop.ScreenSaver.SimulateUserActivity;
      fi
    fi
    sleep "$POLL_INTERVAL";
  done
}

log "Starting (devices: $BT_DEVICE_MACS, lock: $LOCK_THRESHOLD dBm, unlock: $UNLOCK_THRESHOLD dBm)";

if ! any_in_range "$UNLOCK_THRESHOLD"; then
  log "No devices in range at startup, waiting...";
  wait_for_device;
  log "Device in range, starting monitoring";
fi

monitor;
