#!/bin/sh
set -e;

# ── Constants ────────────────────────────────────────────────────────────────

readonly TARGET_CONFIG="${HOME}/.nix-target";
readonly NIX_CONFIG_FILE="${HOME}/.config/nix/nix.conf";
readonly NIX_EXPERIMENTAL_CONFIG='experimental-features = nix-command flakes';

# ── Help ─────────────────────────────────────────────────────────────────────

show_help() {
  cat <<'EOF'
Usage:
  env-load user <target> [<path|ref>] [--update]   Apply a target home environment
  env-load user clean                               Remove unreferenced user Nix store paths
  env-load system <device> [<path|ref>] [--update] Apply a device OS environment for NixOS systems
  env-load system clean                             Remove unreferenced system Nix store paths
  env-load clean                                    Remove unreferenced user and system Nix store paths
  env-load purge                                    Delete all old generations and collect garbage (no rollback)
  env-load refs list                                List tracked refs and their symlinks
  env-load refs sync                                Update all refs to latest upstream
  env-load refs add <org/repo> <repo-path> [<name>] Add a resource from a GitHub ref
  env-load refs rm <name>                           Remove a resource symlink
  env-load help                                     Show this help message

Options:
  --update      Update flake inputs before running the command

Arguments:
  <path|ref>    Local path to repo or git ref (branch/tag). Defaults to 'main'.
                  Local:  env-load user notebook ~/environment
                  Remote: env-load user notebook my-branch
  <org/repo>    GitHub organization and repository (e.g. anthropic/skills)
  <repo-path>   Path to resource within the repository (e.g. skills/skill-creator)
  <name>        Local name for the symlink, defaults to last component of repo-path
EOF
}

die() {
  echo "error: $1";
  echo;
  show_help;
  exit 1;
}

fail() {
  echo "error: $1";
  exit 1;
}

# ── Argument parsing ──────────────────────────────────────────────────────────

parse_args() {
  local arg1=${1:-${TARGET:-}};
  local arg2=${2:-};
  local arg3=${3:-};

  UPDATE=false;

  case "${arg1}" in
    user|system)
      COMMAND="${arg1}";
      COMMAND_ARG="${arg2}";
      REFERENCE="${arg3:-${TARGET_REF:-main}}";
      ;;
    help|clean|purge|refs|'')
      COMMAND="${arg1:-help}";
      COMMAND_ARG="${arg2}";
      REFS_ARG1="${arg3:-}";
      REFS_ARG2="${4:-}";
      ;;
    *)
      [ -n "${arg2}" ] && die "unknown command '${arg1}'.";
      COMMAND="user";
      COMMAND_ARG="${arg1}";
      REFERENCE="${TARGET_REF:-main}";
      ;;
  esac

  for arg in "$@"; do
    [ "${arg}" = "--update" ] && UPDATE=true;
  done

  if [ -d "${REFERENCE}" ]; then
    HOME_URL="${REFERENCE}";
    DEVICES_URL="${REFERENCE}/devices";
  else
    HOME_URL="github:git-rafael/environment?ref=${REFERENCE}";
    DEVICES_URL="github:git-rafael/environment?dir=devices&ref=${REFERENCE}";
  fi
}

# ── Platform setup ────────────────────────────────────────────────────────────

setup_platform() {
  if [ -f /etc/alpine-release ]; then
    export USER=${USER:-root};
  elif [ -n "${TERMUX_VERSION}" ]; then
    export GC_NPROCS=1;
    export USER=${USER:-null};
  fi
  export NIX_INSTALLER_NO_MODIFY_PROFILE=true;
}

# ── Nix installation ──────────────────────────────────────────────────────────

prepare_alpine() {
  mkdir -p /nix /etc/nix;
  printf "sandbox = false\nfilter-syscalls = false\n" > /etc/nix/nix.conf;
  apk --no-cache add sudo xz >/dev/null;
  test $(getent group nixbld) || addgroup -g 30000 -S nixbld;
  for i in $(seq 1 30); do
    test $(id -u "nixbld$i" 2>/dev/null) || \
      adduser -S -D -h /var/empty -g "Nix build user $i" -u $((30000 + i)) -G nixbld "nixbld$i";
  done
}

prepare_termux() {
  mkdir -p /nix /etc/nix;
  printf "sandbox = false\n" > /etc/nix/nix.conf;
  printf "nameserver 1.1.1.1\n" > /etc/resolv.conf;
}

install_nix() {
  if command -v nix >/dev/null 2>&1; then return; fi

  if [ -f /etc/alpine-release ]; then
    prepare_alpine;
  elif [ -n "${TERMUX_VERSION}" ]; then
    prepare_termux;
  fi

  curl -sL https://nixos.org/nix/install | sh -s -- --no-daemon;
  . ${HOME}/.nix-profile/etc/profile.d/nix.sh;
  nix-env --set-flag priority 0 nix;
}

# ── Nix configuration ─────────────────────────────────────────────────────────

configure_nix() {
  mkdir -p "$(dirname ${NIX_CONFIG_FILE})";
  touch "${NIX_CONFIG_FILE}";
  if ! grep -Fxq "${NIX_EXPERIMENTAL_CONFIG}" "${NIX_CONFIG_FILE}"; then
    echo "${NIX_EXPERIMENTAL_CONFIG}" >> "${NIX_CONFIG_FILE}";
  fi
}

# ── Commands ──────────────────────────────────────────────────────────────────

clean_home() {
  nix-collect-garbage ${1:-} --quiet;
}

clean_os() {
  sudo nix-collect-garbage ${1:-} --quiet;
}

cmd_system() {
  if [ "${COMMAND_ARG}" = "clean" ]; then
    clean_os;
    return;
  fi

  [ -z "${COMMAND_ARG}" ] && die "'system' requires a device name or 'clean'.";

  require_sudo;

  [ -d "${REFERENCE}" ] && sudo git config --global --add safe.directory "$(realpath "${REFERENCE}")";
  [ "${UPDATE}" = true ] && nix flake update --flake "${DEVICES_URL}";
  sudo nixos-rebuild switch --flake "${DEVICES_URL}#${COMMAND_ARG}";
  clean_home;
  clean_os;
}

cmd_user() {
  if [ "${COMMAND_ARG}" = "clean" ]; then
    clean_home;
    return;
  fi

  local target="${COMMAND_ARG}";
  if [ -z "${target}" ]; then
    target="$(cat ${TARGET_CONFIG} 2>/dev/null || true)";
    [ -z "${target}" ] && die "'user' requires a target name or 'clean'.";
  fi

  [ "${UPDATE}" = true ] && nix flake update --flake "${HOME_URL}";

  local target_path="${HOME_URL}#homeConfigurations.${target}.activationPackage";
  nix build "${target_path}" --no-link && $(nix path-info "${target_path}")/activate;
  printf "${target}" > "${TARGET_CONFIG}";
  clean_home;
}

require_sudo() {
  if [ "$(id -u)" -ne 0 ] && ! sudo -n true 2>/dev/null; then
    fail "'env-load ${COMMAND}' requires sudo access.";
  fi
}

cmd_clean() {
  require_sudo;
  clean_home;
  clean_os;
}

cmd_refs() {
  local subcmd="${COMMAND_ARG:-}";
  local repo_ref="${REFS_ARG1:-}";
  local repo_path="${REFS_ARG2:-}";

  local repo_root;
  repo_root="$(git rev-parse --show-toplevel)";
  local refs_dir="${repo_root}/.refs";
  local skills_dir="${repo_root}/resources/skills";

  case "${subcmd}" in
    list)
      refs_list "${refs_dir}" "${skills_dir}";
      ;;
    sync)
      refs_sync "${refs_dir}";
      ;;
    add)
      [ -z "${repo_ref}" ]  && die "'refs add' requires <org/repo>.";
      [ -z "${repo_path}" ] && die "'refs add' requires <repo-path>.";
      local name="${5:-$(basename "${repo_path}")}";
      refs_add "${refs_dir}" "${skills_dir}" "${repo_ref}" "${repo_path}" "${name}";
      ;;
    rm)
      [ -z "${repo_ref}" ] && die "'refs rm' requires <name>.";
      refs_rm "${refs_dir}" "${skills_dir}" "${repo_ref}";
      ;;
    *)
      die "'refs' requires a subcommand: list, sync, add, rm.";
      ;;
  esac
}

refs_list() {
  local refs_dir="$1" skills_dir="$2";

  echo "Refs:";
  if [ -d "${refs_dir}" ]; then
    find "${refs_dir}" -mindepth 2 -maxdepth 2 -type d | sort | while read -r ref_path; do
      local org repo remote;
      org="$(basename "$(dirname "${ref_path}")")";
      repo="$(basename "${ref_path}")";
      remote="$(git -C "${ref_path}" remote get-url origin 2>/dev/null || echo '?')";
      local sparse;
      sparse="$(git -C "${ref_path}" sparse-checkout list 2>/dev/null | tr '\n' ' ' | sed 's/ *$//')";
      echo "  ${org}/${repo}  ${remote}";
      [ -n "${sparse}" ] && echo "    paths: ${sparse}";
    done
  else
    echo "  (none)";
  fi

  echo "";
  echo "Symlinks:";
  if [ -d "${skills_dir}" ]; then
    find "${skills_dir}" -maxdepth 1 -type l | sort | while read -r link; do
      local target;
      target="$(readlink "${link}")";
      echo "  $(basename "${link}")  →  ${target}";
    done
  else
    echo "  (none)";
  fi
}

refs_sync() {
  local refs_dir="$1";
  echo "Syncing refs...";
  git -C "$(dirname "${refs_dir}")" submodule update --remote --merge -- \
    $(git -C "$(dirname "${refs_dir}")" submodule foreach --quiet 'echo $sm_path' | grep "^\.refs/" | tr '\n' ' ');
  echo "Done.";
}

refs_add() {
  local refs_dir="$1" skills_dir="$2" org_repo="$3" repo_path="$4" name="$5";
  local org repo submodule_path url link_path link_target;

  org="$(echo "${org_repo}" | cut -d/ -f1)";
  repo="$(echo "${org_repo}" | cut -d/ -f2)";
  submodule_path=".refs/${org}/${repo}";
  url="https://github.com/${org}/${repo}.git";
  link_path="${skills_dir}/${name}";
  # relative path from resources/skills/ to .refs/<org>/<repo>/<repo-path>
  link_target="../../.refs/${org}/${repo}/${repo_path}";

  local repo_root;
  repo_root="$(dirname "${refs_dir}")";

  if [ ! -d "${repo_root}/${submodule_path}" ]; then
    echo "Adding submodule ${org}/${repo}...";
    git -C "${repo_root}" submodule add --depth=1 "${url}" "${submodule_path}";
    git -C "${repo_root}/${submodule_path}" sparse-checkout init --cone;
  fi

  echo "Adding sparse-checkout path: ${repo_path}";
  git -C "${repo_root}/${submodule_path}" sparse-checkout add "${repo_path}";

  if [ -e "${link_path}" ] || [ -L "${link_path}" ]; then
    fail "symlink '${name}' already exists in resources/skills/. Use 'refs rm ${name}' first.";
  fi

  mkdir -p "${skills_dir}";
  ln -s "${link_target}" "${link_path}";
  echo "Added: resources/skills/${name}  →  ${link_target}";
}

refs_rm() {
  local refs_dir="$1" skills_dir="$2" name="$3";
  local link_path="${skills_dir}/${name}";

  if [ ! -L "${link_path}" ]; then
    fail "no symlink '${name}' found in resources/skills/.";
  fi

  local target org repo repo_path submodule_path;
  target="$(readlink "${link_path}")";
  # target format: ../../.refs/<org>/<repo>/<repo-path>
  repo_path="$(echo "${target}" | sed 's|.*\.refs/[^/]*/[^/]*/||')";
  org="$(echo "${target}" | sed 's|.*\.refs/\([^/]*\)/.*|\1|')";
  repo="$(echo "${target}" | sed 's|.*\.refs/[^/]*/\([^/]*\)/.*|\1|')";
  submodule_path=".refs/${org}/${repo}";

  rm "${link_path}";
  echo "Removed symlink: resources/skills/${name}";

  local repo_root;
  repo_root="$(dirname "${refs_dir}")";

  if [ -d "${repo_root}/${submodule_path}" ]; then
    echo "Removing sparse-checkout path: ${repo_path}";
    local remaining;
    remaining="$(git -C "${repo_root}/${submodule_path}" sparse-checkout list 2>/dev/null | grep -v "^${repo_path}$" || true)";
    if [ -z "${remaining}" ]; then
      echo "No more paths tracked from ${org}/${repo}. Removing submodule...";
      git -C "${repo_root}" submodule deinit -f "${submodule_path}";
      git -C "${repo_root}" rm -f "${submodule_path}";
      rm -rf "${repo_root}/.git/modules/${submodule_path}";
    else
      git -C "${repo_root}/${submodule_path}" sparse-checkout set ${remaining};
    fi
  fi
}

cmd_purge() {
  require_sudo;
  echo "WARNING: This will delete ALL old Nix generations for both user and system.";
  echo "You will lose the ability to roll back to any previous configuration.";
  echo;
  printf "Type 'yes' to confirm: ";
  read confirm;
  [ "${confirm}" = "yes" ] || { echo "Aborted."; exit 0; };
  clean_home -d;
  clean_os -d;
}

# ── Main ──────────────────────────────────────────────────────────────────────

parse_args "$@";

case "${COMMAND}" in
  help) show_help; exit 0 ;;
  refs) cmd_refs;  exit 0 ;;
esac

setup_platform;
install_nix;
configure_nix;

case "${COMMAND}" in
  system) cmd_system ;;
  user)   cmd_user   ;;
  clean)  cmd_clean  ;;
  purge)  cmd_purge  ;;
  *)      die "unknown command '${COMMAND}'." ;;
esac
