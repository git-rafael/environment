#!/bin/sh
set -e;

# ── Constants ────────────────────────────────────────────────────────────────

# When invoked via `sudo`, HOME becomes /root; recover the real user's home.
if [ -n "${SUDO_USER:-}" ]; then
  REAL_HOME="$(getent passwd "${SUDO_USER}" | cut -d: -f6)";
else
  REAL_HOME="${HOME}";
fi

readonly TARGET_CONFIG="${REAL_HOME}/.nix-target";
readonly DEVICE_CONFIG="${REAL_HOME}/.nix-device";
readonly NIX_CONFIG_FILE="${REAL_HOME}/.config/nix/nix.conf";
readonly NIX_EXPERIMENTAL_CONFIG='experimental-features = nix-command flakes';

# ── Help ─────────────────────────────────────────────────────────────────────

show_help() {
  cat <<'EOF'
Usage:
  env-load user <target> [<path|ref>] [--update]   Apply a target home environment
  env-load user clean                               Remove unreferenced user Nix store paths
  env-load system <device> [<path|ref>] [--update] Apply a device OS environment for NixOS systems
  env-load system init <path>                      Initialize a new NixOS device in the repo
  env-load system enroll <path>                    Enroll Secure Boot keys and TPM2 LUKS tokens
  env-load system clean                             Remove unreferenced system Nix store paths
  env-load clean                                    Remove unreferenced user and system Nix store paths
  env-load purge                                    Delete all old generations and collect garbage (no rollback)
  env-load push                                     Squash unpushed commits since last apply and push
  env-load help                                     Show this help message

Options:
  --update      Update flake inputs before running the command. For local user
                environments, also refresh npm packages declared under
                sources/.npm/packages/packages.tsv.

Arguments:
  <path|ref>    Local path to repo or git ref (branch/tag). Defaults to 'main'.
                  Local:  env-load user notebook ~/environment
                  Remote: env-load user notebook my-branch
EOF
}

die() {
  echo "error: $1";
  echo;
  show_help;
  exit 1;
}

fail() {
  echo "error: $1";
  exit 1;
}

# ── Interactive prompts ──────────────────────────────────────────────────────

ask_text() {
  local prompt="$1" default="$2" ans;
  if [ -n "${default}" ]; then
    printf "%s [%s] " "${prompt}" "${default}" >&2;
  else
    printf "%s " "${prompt}" >&2;
  fi
  read ans </dev/tty || ans="";
  [ -z "${ans}" ] && ans="${default}";
  printf "%s" "${ans}";
}

ask_yesno() {
  local prompt="$1" default="$2" ans;
  printf "%s [%s] " "${prompt}" "${default}" >&2;
  read ans </dev/tty || ans="";
  [ -z "${ans}" ] && ans="${default}";
  case "${ans}" in
    y|Y|yes|YES) return 0 ;;
    *) return 1 ;;
  esac
}

# ── Validation & escaping ────────────────────────────────────────────────────

validate_name() {
  case "$1" in
    ''|*[!a-zA-Z0-9_-]*) return 1 ;;
    *) return 0 ;;
  esac
}

nix_escape() {
  printf "%s" "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' -e 's/\${/\\${/g';
}

# ── Argument parsing ──────────────────────────────────────────────────────────

parse_args() {
  local arg1=${1:-${TARGET:-}};
  local arg2=${2:-};
  local arg3=${3:-};

  UPDATE=false;

  case "${arg1}" in
    user|system)
      COMMAND="${arg1}";
      COMMAND_ARG="${arg2}";
      REFERENCE="${arg3:-${TARGET_REF:-main}}";
      ;;
    help|clean|purge|push|'')
      COMMAND="${arg1:-help}";
      COMMAND_ARG="${arg2}";
      ;;
    *)
      [ -n "${arg2}" ] && die "unknown command '${arg1}'.";
      COMMAND="user";
      COMMAND_ARG="${arg1}";
      REFERENCE="${TARGET_REF:-main}";
      ;;
  esac

  for arg in "$@"; do
    [ "${arg}" = "--update" ] && UPDATE=true;
  done

  if [ -d "${REFERENCE}" ]; then
    if [ ! -f "${REFERENCE}/flake.nix" ]; then
      local git_root;
      git_root="$(git -C "${REFERENCE}" rev-parse --show-toplevel 2>/dev/null)" \
        || die "'${REFERENCE}' does not appear to be the environment repo (no flake.nix found).";
      REFERENCE="${git_root}";
    fi
    [ -f "${REFERENCE}/flake.nix" ] || die "'${REFERENCE}' does not appear to be the environment repo (no flake.nix found).";
    git -C "${REFERENCE}" remote -v 2>/dev/null | grep -q "git-rafael/environment" \
      || die "'${REFERENCE}' is not the git-rafael/environment repository.";
    HOME_URL="git+file://$(realpath "${REFERENCE}")";
    DEVICES_URL="git+file://$(realpath "${REFERENCE}")?dir=devices";
  else
    HOME_URL="github:git-rafael/environment?ref=${REFERENCE}";
    DEVICES_URL="github:git-rafael/environment?dir=devices&ref=${REFERENCE}";
  fi
}

# ── Platform setup ────────────────────────────────────────────────────────────

setup_platform() {
  if [ -f /etc/alpine-release ]; then
    export USER=${USER:-root};
  elif [ -n "${TERMUX_VERSION}" ]; then
    export GC_NPROCS=1;
    export USER=${USER:-null};
  fi
  export NIX_INSTALLER_NO_MODIFY_PROFILE=true;
}

# ── Nix installation ──────────────────────────────────────────────────────────

prepare_alpine() {
  mkdir -p /nix /etc/nix;
  printf "sandbox = false\nfilter-syscalls = false\n" > /etc/nix/nix.conf;
  apk --no-cache add sudo xz >/dev/null;
  test $(getent group nixbld) || addgroup -g 30000 -S nixbld;
  for i in $(seq 1 30); do
    test $(id -u "nixbld$i" 2>/dev/null) || \
      adduser -S -D -h /var/empty -g "Nix build user $i" -u $((30000 + i)) -G nixbld "nixbld$i";
  done
}

prepare_termux() {
  mkdir -p /nix /etc/nix;
  printf "sandbox = false\n" > /etc/nix/nix.conf;
  printf "nameserver 1.1.1.1\n" > /etc/resolv.conf;
}

install_nix() {
  if command -v nix >/dev/null 2>&1; then return; fi

  if [ -f /etc/alpine-release ]; then
    prepare_alpine;
  elif [ -n "${TERMUX_VERSION}" ]; then
    prepare_termux;
  fi

  curl -sL https://nixos.org/nix/install | sh -s -- --no-daemon;
  . ${HOME}/.nix-profile/etc/profile.d/nix.sh;
  nix-env --set-flag priority 0 nix;
}

# ── Nix configuration ─────────────────────────────────────────────────────────

configure_nix() {
  mkdir -p "$(dirname ${NIX_CONFIG_FILE})";
  touch "${NIX_CONFIG_FILE}";
  if ! grep -Fxq "${NIX_EXPERIMENTAL_CONFIG}" "${NIX_CONFIG_FILE}"; then
    echo "${NIX_EXPERIMENTAL_CONFIG}" >> "${NIX_CONFIG_FILE}";
  fi
}

# ── npm package updates ───────────────────────────────────────────────────────

run_npm() {
  if command -v npm >/dev/null 2>&1; then
    npm "$@";
  else
    nix shell nixpkgs#nodejs --command npm "$@";
  fi
}

json_hash() {
  sed -n 's/.*"hash":"\([^"]*\)".*/\1/p';
}

update_npm_package_lock() {
  local lock_dir="$1" package_name="$2";
  local agents_nix="${REFERENCE}/sources/agents.nix";
  local lock_path="${REFERENCE}/sources/.npm/packages/${lock_dir}/package-lock.json";

  [ -f "${agents_nix}" ] || fail "sources/agents.nix not found.";
  [ -d "$(dirname "${lock_path}")" ] || fail "npm lock directory not found: $(dirname "${lock_path}")";

  echo "Updating npm package ${package_name} (${lock_dir})...";

  local version tarball src_hash tmp tgz deps_hash;
  version="$(run_npm view "${package_name}" version --silent)";
  [ -n "${version}" ] || fail "could not resolve latest npm version for ${package_name}.";

  tarball="$(run_npm view "${package_name}@${version}" dist.tarball --silent)";
  [ -n "${tarball}" ] || fail "could not resolve npm tarball for ${package_name}@${version}.";

  src_hash="$(nix store prefetch-file --json "${tarball}" | json_hash)";
  [ -n "${src_hash}" ] || fail "could not prefetch ${tarball}.";

  tmp="$(mktemp -d)" || fail "failed to create temp directory.";
  (
    cd "${tmp}";
    run_npm pack "${package_name}@${version}" --ignore-scripts --silent >/dev/null;
    tgz="$(ls ./*.tgz | head -n 1)";
    [ -n "${tgz}" ] || fail "npm pack did not produce a tarball for ${package_name}@${version}.";
    tar -xzf "${tgz}";
    cd package;
    run_npm install --package-lock-only --ignore-scripts --silent >/dev/null;
    cp package-lock.json "${lock_path}";
  );
  rm -rf "${tmp}";

  deps_hash="$(nix run nixpkgs#prefetch-npm-deps -- "${lock_path}" | tail -n 1)";
  case "${deps_hash}" in
    sha256-*) ;;
    *) fail "could not compute npmDepsHash for ${package_name}." ;;
  esac

  local tmp_agents;
  tmp_agents="$(mktemp)" || fail "failed to create temp file.";
  awk \
    -v attr="${lock_dir}" \
    -v version="${version}" \
    -v src_hash="${src_hash}" \
    -v deps_hash="${deps_hash}" '
      $0 == "  " attr " = let" { in_block = 1 }
      in_block && $0 ~ /^    version = "/ {
        print "    version = \"" version "\";";
        next;
      }
      in_block && $0 ~ /^        hash = "/ {
        print "        hash = \"" src_hash "\";";
        next;
      }
      in_block && $0 ~ /^      npmDepsHash = "/ {
        print "      npmDepsHash = \"" deps_hash "\";";
        next;
      }
      { print }
      in_block && $0 == "  };" { in_block = 0 }
    ' "${agents_nix}" > "${tmp_agents}";
  mv "${tmp_agents}" "${agents_nix}";

  echo "  ${package_name}@${version}";
}

update_environment_npm_packages() {
  [ -d "${REFERENCE}" ] || return 0;

  local manifest="${REFERENCE}/sources/.npm/packages/packages.tsv";
  [ -f "${manifest}" ] || return 0;

  echo "Updating environment npm packages...";

  while read -r lock_dir package_name _; do
    case "${lock_dir}" in
      ''|'#'*) continue ;;
    esac
    [ -n "${package_name}" ] || fail "invalid npm package manifest entry for '${lock_dir}'.";
    update_npm_package_lock "${lock_dir}" "${package_name}";
  done < "${manifest}";
}

# ── Commands ──────────────────────────────────────────────────────────────────

clean_home() {
  nix-collect-garbage ${1:-} --quiet;
}

clean_os() {
  sudo nix-collect-garbage ${1:-} --quiet;
}

cmd_system_init() {
  [ -f /etc/NIXOS ] || fail "'system init' only works on NixOS.";
  [ -f /etc/nixos/hardware-configuration.nix ] || fail "/etc/nixos/hardware-configuration.nix not found.";
  [ -f /etc/nixos/configuration.nix ] || fail "/etc/nixos/configuration.nix not found.";
  [ -d "${REFERENCE}" ] || fail "'system init' requires a local clone of git-rafael/environment. Clone it first and re-run: git clone https://github.com/git-rafael/environment.git <path>";

  require_clean_repo;

  ensure_git_identity;

  echo "Initializing new system device...";
  echo;

  local default_user="${SUDO_USER:-${USER}}";
  local default_desc;
  default_desc="$(getent passwd "${default_user}" | cut -d: -f5 | cut -d, -f1)";

  local hostname username description description_esc;
  hostname="$(ask_text "Hostname:" "")";
  validate_name "${hostname}" || fail "invalid hostname. Allowed: letters, digits, '_', '-'.";

  local device_dir="${REFERENCE}/devices/${hostname}";
  if [ -e "${device_dir}" ]; then
    echo "devices/${hostname} already exists.";
    if ask_yesno "Delete it and re-initialize?" "N"; then
      rm -rf "${device_dir}";
      # Remove the existing nixosConfigurations entry from devices/flake.nix
      local flake="${REFERENCE}/devices/flake.nix";
      local tmp_flake;
      tmp_flake="$(mktemp)" || fail "failed to create temp file.";
      awk -v host="${hostname}" '
        BEGIN { skip = 0 }
        $0 ~ "nixosConfigurations\\.\"" host "\"" { skip = 1; next }
        skip && /^    };$/ { skip = 0; next }
        !skip { print }
      ' "${flake}" > "${tmp_flake}";
      mv "${tmp_flake}" "${flake}";
      git -C "${REFERENCE}" add "devices/";
      git -C "${REFERENCE}" commit -m "Remove ${hostname} device for re-init" --quiet;
    else
      fail "aborted.";
    fi
  fi

  username="$(ask_text "Username:" "${default_user}")";
  validate_name "${username}" || fail "invalid username. Allowed: letters, digits, '_', '-'.";

  description="$(ask_text "Description:" "${default_desc}")";
  description_esc="$(nix_escape "${description}")";

  local has_fingerprint=false use_thinkpad_kbd=false enable_warp=false enable_lanzaboote=false;
  if ask_yesno "Has fingerprint reader?" "N"; then has_fingerprint=true; fi
  if ask_yesno "Use ThinkPad keyboard xkb variant?" "N"; then use_thinkpad_kbd=true; fi
  if ask_yesno "Enable Secure Boot (lanzaboote)?" "N"; then enable_lanzaboote=true; fi
  if ask_yesno "Enable cloudflare-warp?" "N"; then enable_warp=true; fi

  mkdir -p "${device_dir}";

  # hardware-configuration.nix: copy scan result and merge any boot.initrd.luks.devices
  # lines that nixos-generate-config placed in /etc/nixos/configuration.nix.
  cp /etc/nixos/hardware-configuration.nix "${device_dir}/hardware-configuration.nix";
  local luks_lines;
  luks_lines="$(grep -E '^[[:space:]]*boot\.initrd\.luks\.devices\.' /etc/nixos/configuration.nix 2>/dev/null || true)";
  if [ -n "${luks_lines}" ]; then
    local tmp_hw;
    tmp_hw="$(mktemp)" || fail "failed to create temp file.";
    LUKS_LINES="${luks_lines}" awk '
      BEGIN { inserted = 0 }
      /^}$/ && !inserted { print ""; print ENVIRON["LUKS_LINES"]; inserted = 1 }
      { print }
    ' "${device_dir}/hardware-configuration.nix" > "${tmp_hw}";
    mv "${tmp_hw}" "${device_dir}/hardware-configuration.nix";
  fi

  # Lanzaboote/TPM2: add crypttabExtraOpts to every LUKS volume.
  if [ "${enable_lanzaboote}" = true ]; then
    local tmp_hw;
    tmp_hw="$(mktemp)" || fail "failed to create temp file.";
    awk '
      { print }
      /boot\.initrd\.luks\.devices\."[^"]*"\.device[[:space:]]*=/ {
        name = $0;
        sub(/.*boot\.initrd\.luks\.devices\./, "", name);
        sub(/\.device[[:space:]]*=.*/, "", name);
        print "  boot.initrd.luks.devices." name ".crypttabExtraOpts = [ \"tpm2-device=auto\" ];";
      }
    ' "${device_dir}/hardware-configuration.nix" > "${tmp_hw}";
    mv "${tmp_hw}" "${device_dir}/hardware-configuration.nix";
  fi

  # configuration.nix: render from template, mirroring the existing device style.
  {
    cat <<EOF
{ inputs, config, pkgs, ... }:
{
  imports = [
    ./hardware-configuration.nix
    ../os.nix
    ../ui.nix
  ];

  networking.hostName = "${hostname}";

  # Device options
  device.username = "${username}";
  device.userDescription = "${description_esc}";

  device.hasFingerprint = ${has_fingerprint};
EOF
    if [ "${enable_lanzaboote}" = true ]; then
      cat <<'EOF'

  # Secure Boot via Lanzaboote (replaces systemd-boot)
  boot.lanzaboote = {
    enable = true;
    pkiBundle = "/var/lib/sbctl";
  };

  # TPM2-based LUKS auto-unlock (requires systemd initrd; enrollment done
  # at runtime via systemd-cryptenroll, see hardware-configuration.nix).
  boot.initrd.systemd.enable = true;

  environment.systemPackages = [ pkgs.sbctl ];
EOF
    fi
    if [ "${use_thinkpad_kbd}" = true ]; then
      cat <<'EOF'

  # ThinkPad keyboard layout variant
  services.xserver.xkb.variant = "thinkpad";
EOF
    fi
    if [ "${enable_warp}" = true ]; then
      cat <<'EOF'

  # Cloudflare warp
  services.cloudflare-warp.enable = true;
  security.pki.certificateFiles = [
    ../../resources/certificates/flash_warp_certificate.crt
  ];
EOF
    fi
    echo '}';
  } > "${device_dir}/configuration.nix";

  # devices/flake.nix: inject new nixosConfigurations entry right before the
  # outputs-closing brace (detected as the last `  };` line).
  local flake="${REFERENCE}/devices/flake.nix";
  local tmp_flake;
  tmp_flake="$(mktemp)" || fail "failed to create temp file.";
  NEW_HOST="${hostname}" LANZABOOTE="${enable_lanzaboote}" awk '
    { lines[NR] = $0 }
    END {
      host = ENVIRON["NEW_HOST"];
      lanza = ENVIRON["LANZABOOTE"];
      close_line = 0;
      for (i = NR; i >= 1; i--) {
        if (lines[i] == "  };") { close_line = i; break }
      }
      for (i = 1; i <= NR; i++) {
        if (i == close_line) {
          print "    nixosConfigurations.\"" host "\" = nixpkgs.lib.nixosSystem {";
          print "      specialArgs = { inherit inputs; };";
          print "      system = \"x86_64-linux\";";
          print "      modules = [";
          if (lanza == "true") {
            print "        lanzaboote.nixosModules.lanzaboote";
          }
          print "        ./" host "/configuration.nix";
          print "      ];";
          print "    };";
        }
        print lines[i];
      }
    }
  ' "${flake}" > "${tmp_flake}";
  if ! grep -q "nixosConfigurations\\.\"${hostname}\"" "${tmp_flake}"; then
    rm -f "${tmp_flake}";
    fail "failed to inject new device into devices/flake.nix (no '  };' insertion point found).";
  fi
  mv "${tmp_flake}" "${flake}";

  git -C "${REFERENCE}" add "devices/flake.nix" "devices/${hostname}";
  git -C "${REFERENCE}" commit -m "Add ${hostname} device" --quiet;

  echo;
  echo "Device '${hostname}' initialized and committed.";
  echo "Review the generated files, then apply with:";
  echo;
  echo "  sudo env-load system ${hostname} ${REFERENCE}";
  echo;
}

apply_system() {
  local device="$1";

  require_sudo;
  require_clean_repo;

  if [ -d "${REFERENCE}" ]; then
    sudo git config --global --add safe.directory "$(realpath "${REFERENCE}")";
  fi;
  if [ "${UPDATE}" = true ]; then nix flake update --flake "${DEVICES_URL}"; fi;

  # Lanzaboote (Secure Boot): ensure sbctl keys exist before rebuilding.
  if [ -d "${REFERENCE}" ] && grep -rq 'lanzaboote' "${REFERENCE}/devices/${device}/configuration.nix" 2>/dev/null; then
    if ! [ -f /var/lib/sbctl/keys/db/db.key ]; then
      echo "Lanzaboote detected but sbctl keys not found. Creating Secure Boot keys...";
      command -v sbctl >/dev/null 2>&1 || fail "sbctl is not installed. Run 'env-load user' first to install it.";
      sudo sbctl create-keys;
    fi
  fi

  sudo nixos-rebuild switch --flake "${DEVICES_URL}#${device}" --quiet --quiet;

  if [ -d "${REFERENCE}" ]; then
    printf "${device}@$(git -C "${REFERENCE}" rev-parse HEAD)" > "${DEVICE_CONFIG}";
  fi

  clean_os;

  # Suggest enrollment if Secure Boot or TPM2 is configured.
  if [ -d "${REFERENCE}" ]; then
    local needs_enroll=false;
    grep -q 'lanzaboote' "${REFERENCE}/devices/${device}/configuration.nix" 2>/dev/null && needs_enroll=true;
    grep -q 'tpm2-device=auto' "${REFERENCE}/devices/${device}/hardware-configuration.nix" 2>/dev/null && needs_enroll=true;
    if [ "${needs_enroll}" = true ]; then
      echo;
      echo "Secure Boot / TPM2 detected. To complete enrollment, run:";
      echo;
      echo "  sudo env-load system enroll ${REFERENCE}";
      echo;
    fi
  fi
}

enroll_secureboot() {
  command -v sbctl >/dev/null 2>&1 || fail "sbctl is not installed. Run 'env-load user' first.";

  # Ensure keys exist.
  if ! [ -f /var/lib/sbctl/keys/db/db.key ]; then
    echo "Creating Secure Boot keys...";
    sudo sbctl create-keys;
  fi

  # Check current status.
  local sb_status;
  sb_status="$(sudo sbctl status 2>&1)";

  # If Secure Boot is already enabled, nothing to do.
  if echo "${sb_status}" | grep -qi "secure boot:.*enabled"; then
    echo "Secure Boot is already enabled.";
    sudo sbctl verify;
    return;
  fi

  # If keys are already enrolled (Setup Mode disabled, but Secure Boot not yet
  # enabled), the user needs to enable Secure Boot in BIOS first.
  if echo "${sb_status}" | grep -qi "installed:.*sbctl is installed"; then
    echo "Secure Boot keys are enrolled but Secure Boot is not yet enabled in BIOS.";
    echo "Enable Secure Boot in BIOS, reboot, then re-run this command for TPM2 enrollment.";
    sudo sbctl verify;
    return 2;
  fi

  # Setup Mode required for first-time key enrollment.
  if echo "${sb_status}" | grep -qi "setup mode:.*disabled"; then
    echo;
    echo "Secure Boot Setup Mode is not enabled.";
    echo "To enroll keys, your BIOS must be in Setup Mode:";
    echo "  1. Reboot and enter BIOS/UEFI settings";
    echo "  2. Find Secure Boot / Key Management settings";
    echo "  3. Delete the Platform Key (PK) or enable 'Custom Mode' / 'Expert Key Management'";
    echo "  4. Save, exit, and re-run this command";
    echo;
    echo "warning: BIOS not in Setup Mode. Skipping Secure Boot enrollment.";
    return 1;
  fi

  # Remove immutable attribute from EFI variables if set (some firmware
  # marks them read-only, which blocks key enrollment).
  for efiv in /sys/firmware/efi/efivars/{PK,KEK,db,dbx}-*; do
    [ -e "${efiv}" ] && sudo chattr -i "${efiv}" 2>/dev/null || true;
  done

  echo "Enrolling Secure Boot keys (Microsoft + firmware built-in)...";
  sudo sbctl enroll-keys --microsoft --firmware-builtin;
  echo "Secure Boot keys enrolled.";
  echo;
  sudo sbctl verify;
  echo;
  echo "Enable Secure Boot in BIOS on next reboot.";
}

enroll_tpm2() {
  local hw_config="$1";

  command -v systemd-cryptenroll >/dev/null 2>&1 || fail "systemd-cryptenroll is not available.";

  # Extract LUKS UUIDs from hardware-configuration.nix.
  local uuids;
  uuids="$(awk -F'by-uuid/' '/boot\.initrd\.luks\.devices\."luks-.*"\.device[[:space:]]*=/ {
    split($2, a, "\""); print a[1]
  }' "${hw_config}")";

  [ -z "${uuids}" ] && { echo "No LUKS volumes found in ${hw_config}."; return; };

  # Prompt for LUKS passphrase once (hidden input) and validate.
  local luks_pass luks_pass_confirm;
  while true; do
    printf "Enter LUKS passphrase: " >&2;
    stty -echo 2>/dev/null || true;
    read luks_pass </dev/tty;
    stty echo 2>/dev/null || true;
    echo >&2;
    printf "Confirm LUKS passphrase: " >&2;
    stty -echo 2>/dev/null || true;
    read luks_pass_confirm </dev/tty;
    stty echo 2>/dev/null || true;
    echo >&2;
    if [ "${luks_pass}" = "${luks_pass_confirm}" ]; then
      break;
    fi
    echo "Passphrases do not match. Try again." >&2;
  done

  echo "Enrolling TPM2 for LUKS volumes...";
  echo "${uuids}" | while IFS= read -r uuid; do
    local dev="/dev/disk/by-uuid/${uuid}";
    if [ ! -e "${dev}" ]; then
      echo "  ${uuid}: device not found, skipping.";
      continue;
    fi
    if sudo cryptsetup luksDump "${dev}" 2>/dev/null | grep -q "systemd-tpm2"; then
      if ask_yesno "  ${uuid}: TPM2 already enrolled. Re-enroll?" "N"; then
        echo "  ${uuid}: Wiping old TPM2 token and re-enrolling (PCRs 0+7)...";
        printf '%s' "${luks_pass}" | sudo systemd-cryptenroll --unlock-key-file=/dev/stdin --wipe-slot=tpm2 --tpm2-device=auto --tpm2-pcrs=0+7 "${dev}";
      else
        echo "  ${uuid}: skipping.";
      fi
    else
      echo "  ${uuid}: Enrolling TPM2 (PCRs 0+7)...";
      printf '%s' "${luks_pass}" | sudo systemd-cryptenroll --unlock-key-file=/dev/stdin --tpm2-device=auto --tpm2-pcrs=0+7 "${dev}";
    fi
  done
}

cmd_system_enroll() {
  [ -f /etc/NIXOS ] || fail "'system enroll' only works on NixOS.";
  [ -d "${REFERENCE}" ] || fail "'system enroll' requires a local repo path.";

  require_sudo;

  # Resolve device name from DEVICE_CONFIG or hostname.
  local device="";
  if [ -f "${DEVICE_CONFIG}" ]; then
    device="$(cut -d@ -f1 "${DEVICE_CONFIG}")";
  fi
  [ -z "${device}" ] && device="$(hostname)";

  local config="${REFERENCE}/devices/${device}/configuration.nix";
  local hw_config="${REFERENCE}/devices/${device}/hardware-configuration.nix";
  [ -f "${config}" ] || fail "device config not found: ${config}";

  local did_something=false;
  local sb_pending=false;

  if grep -q 'lanzaboote' "${config}" 2>/dev/null; then
    local sb_rc=0;
    enroll_secureboot || sb_rc=$?;
    did_something=true;
    # Return code 2 means keys enrolled but Secure Boot not yet enabled in BIOS.
    # TPM2 enrollment must wait until Secure Boot is active (PCR 7 would change).
    [ "${sb_rc}" = 2 ] && sb_pending=true;
  fi

  if grep -q 'tpm2-device=auto' "${hw_config}" 2>/dev/null; then
    if [ "${sb_pending}" = true ]; then
      echo;
      echo "TPM2 enrollment skipped — Secure Boot must be enabled first.";
      echo "After enabling Secure Boot and rebooting, re-run:";
      echo;
      echo "  sudo env-load system enroll ${REFERENCE}";
    else
      enroll_tpm2 "${hw_config}";
    fi
    did_something=true;
  fi

  if [ "${did_something}" = false ]; then
    echo "No Secure Boot or TPM2 enrollment needed for '${device}'.";
  fi
}

cmd_system() {
  if [ "${COMMAND_ARG}" = "clean" ]; then
    clean_os;
    return;
  fi

  if [ "${COMMAND_ARG}" = "init" ]; then
    cmd_system_init;
    return;
  fi

  if [ "${COMMAND_ARG}" = "enroll" ]; then
    cmd_system_enroll;
    return;
  fi

  [ -z "${COMMAND_ARG}" ] && die "'system' requires a device name, 'init', 'enroll', or 'clean'.";

  apply_system "${COMMAND_ARG}";
}

cmd_user() {
  if [ "${COMMAND_ARG}" = "clean" ]; then
    clean_home;
    return;
  fi

  local target="${COMMAND_ARG}";
  if [ -z "${target}" ]; then
    target="$(cut -d@ -f1 "${TARGET_CONFIG}" 2>/dev/null || true)";
    [ -z "${target}" ] && die "'user' requires a target name or 'clean'.";
  fi

  require_clean_repo;

  if [ "${UPDATE}" = true ]; then
    update_environment_npm_packages;
    nix flake update --flake "${HOME_URL}";
  fi;

  local target_path="${HOME_URL}#homeConfigurations.${target}.activationPackage";
  local out;
  out=$(nix build "${target_path}" --no-link --print-out-paths --quiet --quiet) && ${out}/activate;

  if [ -d "${REFERENCE}" ]; then
    printf "${target}@$(git -C "${REFERENCE}" rev-parse HEAD)" > "${TARGET_CONFIG}";
  else
    printf "${target}" > "${TARGET_CONFIG}";
  fi

  clean_home;

  suggest_system_init;
}

# On fresh NixOS installs (no .nix-device yet), nudge the user to run
# 'system init' so this device gets registered in the repo and its
# NixOS configuration applied.
suggest_system_init() {
  [ -f /etc/NIXOS ] || return 0;
  [ -f "${DEVICE_CONFIG}" ] && return 0;
  echo;
  echo "This NixOS device has no system configuration applied yet.";
  echo "To register it in the environment repo and apply it, clone the repo and run 'system init':";
  echo;
  echo "  git clone https://github.com/git-rafael/environment.git ~/Desktop/Codebase/environment";
  echo "  env-load system init ~/Desktop/Codebase/environment";
  echo;
}

require_sudo() {
  if [ "$(id -u)" -ne 0 ] && ! sudo -n true 2>/dev/null; then
    fail "'env-load ${COMMAND}' requires sudo access.";
  fi
}

ensure_git_identity() {
  [ -d "${REFERENCE:-}" ] || return 0;
  if ! git -C "${REFERENCE}" config user.name >/dev/null 2>&1; then
    local name;
    name="$(ask_text "Git user.name not set. Enter your name:" "")";
    [ -z "${name}" ] && fail "git user.name is required.";
    git -C "${REFERENCE}" config user.name "${name}";
  fi
  if ! git -C "${REFERENCE}" config user.email >/dev/null 2>&1; then
    local email;
    email="$(ask_text "Git user.email not set. Enter your email:" "")";
    [ -z "${email}" ] && fail "git user.email is required.";
    git -C "${REFERENCE}" config user.email "${email}";
  fi
}

require_clean_repo() {
  [ -d "${REFERENCE:-}" ] || return 0;
  local status;
  status="$(git -C "${REFERENCE}" status --porcelain 2>/dev/null)";
  [ -z "${status}" ] || fail "repository has uncommitted changes. Commit before applying.";
}

cmd_push() {
  local repo_root;
  repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || fail "not inside a git repository.";

  local target_hash="" device_hash="" oldest_hash="";

  if [ -f "${TARGET_CONFIG}" ]; then
    target_hash="$(cut -d@ -f2 "${TARGET_CONFIG}" 2>/dev/null || true)";
  fi
  if [ -f "${DEVICE_CONFIG}" ]; then
    device_hash="$(cut -d@ -f2 "${DEVICE_CONFIG}" 2>/dev/null || true)";
  fi

  [ -z "${target_hash}" ] && [ -z "${device_hash}" ] && \
    fail "no apply history found. Run 'env-load user' or 'env-load system' with a local path first.";

  if [ -z "${target_hash}" ]; then
    oldest_hash="${device_hash}";
  elif [ -z "${device_hash}" ]; then
    oldest_hash="${target_hash}";
  elif git -C "${repo_root}" merge-base --is-ancestor "${target_hash}" "${device_hash}" 2>/dev/null; then
    oldest_hash="${target_hash}";
  else
    oldest_hash="${device_hash}";
  fi

  # Never squash commits already on the remote — use the more recent of oldest_hash and origin/main.
  local remote_hash;
  remote_hash="$(git -C "${repo_root}" rev-parse origin/main 2>/dev/null || true)";
  if [ -n "${remote_hash}" ] && \
     git -C "${repo_root}" merge-base --is-ancestor "${oldest_hash}" "${remote_hash}" 2>/dev/null; then
    oldest_hash="${remote_hash}";
  fi

  local commits;
  commits="$(git -C "${repo_root}" log --oneline "${oldest_hash}..HEAD" 2>/dev/null)";
  [ -z "${commits}" ] && { echo "Nothing to push."; return; };

  echo "Commits to squash:";
  echo "${commits}";
  echo;
  printf "Squash and push? [y/N] ";
  read confirm;
  [ "${confirm}" = "y" ] || { echo "Aborted."; exit 0; };

  local msg;
  msg="$(git -C "${repo_root}" log --format="%s" --reverse "${oldest_hash}..HEAD")";

  git -C "${repo_root}" reset --soft "${oldest_hash}";
  git -C "${repo_root}" commit -m "${msg}";
  git -C "${repo_root}" push --force-with-lease;
  echo "Done.";
}

cmd_clean() {
  require_sudo;
  clean_home;
  clean_os;
}

cmd_purge() {
  require_sudo;
  echo "WARNING: This will delete ALL old Nix generations for both user and system.";
  echo "You will lose the ability to roll back to any previous configuration.";
  echo;
  printf "Type 'yes' to confirm: ";
  read confirm;
  [ "${confirm}" = "yes" ] || { echo "Aborted."; exit 0; };
  clean_home -d;
  clean_os -d;
}

# ── Main ──────────────────────────────────────────────────────────────────────

parse_args "$@";

case "${COMMAND}" in
  help) show_help; exit 0 ;;
  push) cmd_push;  exit 0 ;;
esac

setup_platform;
install_nix;
configure_nix;

case "${COMMAND}" in
  system) cmd_system ;;
  user)   cmd_user   ;;
  clean)  cmd_clean  ;;
  purge)  cmd_purge  ;;
  *)      die "unknown command '${COMMAND}'." ;;
esac
